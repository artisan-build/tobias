# Tobias provider credentials.
# For global use, prefer exporting these in your shell profile instead of a .env.
# Only set the providers you actually use.

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Local models (no key required — just point at the server)
LMSTUDIO_URL=http://127.0.0.1:1234/v1
OLLAMA_URL=http://localhost:11434
